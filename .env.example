# ARPvs Configuration

# Root directory to scan for audio files
SCAN_ROOT=C:\Users\YourName\Music

# Server host and port
HOST=127.0.0.1
PORT=8000

# Window dimensions and title
WINDOW_WIDTH=1200
WINDOW_HEIGHT=800
WINDOW_MIN_WIDTH=800
WINDOW_MIN_HEIGHT=500
WINDOW_TITLE=ARPvs

# Search result limit
SEARCH_LIMIT=50

# Audio streaming chunk size (bytes)
STREAM_CHUNK_SIZE=65536
